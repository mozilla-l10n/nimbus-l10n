## Branch: survey

# Title shown at the top of the microsurvey callout
nova-survey-title = Help improve the Firefox redesign
# Question 1: satisfaction (CSAT) with the Firefox redesign preview in Nightly
nova-q1-satisfaction = In this version of Nightly, you’re seeing an early preview of Firefox’s redesign. How satisfied are you with it so far?
# Satisfaction scale option (lowest)
nova-opt-very-dissatisfied = Very dissatisfied
# Satisfaction scale option
nova-opt-dissatisfied = Dissatisfied
# Satisfaction scale option (neutral midpoint)
nova-opt-neutral = Neutral
# Satisfaction scale option
nova-opt-satisfied = Satisfied
# Satisfaction scale option (highest)
nova-opt-very-satisfied = Very satisfied
# Satisfaction option for users who have not noticed the redesign
nova-opt-not-noticed = I haven’t noticed a change
# Label for the button that submits the answer and advances the survey
nova-button-submit = Submit
# Link that opens the Firefox privacy notice
nova-button-privacy = Privacy notice
# Question 2: open-ended write-in about the redesign
nova-q2-writein = What stands out to you about the redesign, good or bad?
# Disclaimer shown above the submit button on the write-in question
nova-survey-disclaimer = Please don’t share personal information.
# Confirmation title shown on the final screen after the survey is submitted
nova-survey-thanks-title = Thanks for your feedback!
